# Telora Backend - Environment Variables
# Copie ce fichier en .env et remplis les valeurs

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/telora

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:5173,exp://localhost:8081
