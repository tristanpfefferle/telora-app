{
  "expo": {
    "name": "Telora",
    "slug": "telora-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "telora",
    "userInterfaceStyle": "dark",
    "sdkVersion": "54.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "backgroundColor": "#0A0A0F",
    "androidStatusBar": {
      "backgroundColor": "#0A0A0F",
      "barStyle": "light-content"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.telora.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Telora utilise Face ID pour sécuriser ton accès."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.telora.app",
      "versionCode": 1,
      "navigationBarColor": "#0A0A0F"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://api.telora.ch",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "19c2b13d-caa6-4684-879f-cee10659f0e7"
      }
    },
    "owner": "tristan.pfefferle"
  }
}